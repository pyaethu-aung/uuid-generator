{
  "$schema": "https://design-tokens.org/schema.json",
  "meta": {
    "name": "idlab",
    "version": "1.0.0",
    "description": "Terminal-luxury design tokens distilled from the idlab ID workbench UI.",
    "format": "W3C Design Tokens (Community Group draft)"
  },

  "color": {
    "$description": "All colors authored in OKLCH. Neutrals share a warm-grey hue (~60deg) with chroma capped at 0.008 to keep them honest. Accents share lightness 0.74-0.86 and chroma 0.18-0.20 — vary hue only.",

    "bg": {
      "dark": {
        "0": { "$value": "oklch(0.16 0.005 60)", "$type": "color", "$description": "App canvas, top bar, rail surface" },
        "1": { "$value": "oklch(0.18 0.005 60)", "$type": "color", "$description": "Workbench shell, panel surface" },
        "2": { "$value": "oklch(0.21 0.006 60)", "$type": "color", "$description": "Row hover, controls inset, kbd surface" }
      },
      "light": {
        "0": { "$value": "oklch(0.985 0.003 60)", "$type": "color" },
        "1": { "$value": "oklch(0.965 0.004 60)", "$type": "color" },
        "2": { "$value": "oklch(0.945 0.005 60)", "$type": "color" }
      }
    },

    "seam": {
      "$description": "Hairline borders that segment the workbench. seam-2 is the hover/elevated step.",
      "dark": {
        "1": { "$value": "oklch(0.28 0.006 60)", "$type": "color" },
        "2": { "$value": "oklch(0.36 0.008 60)", "$type": "color" }
      },
      "light": {
        "1": { "$value": "oklch(0.88 0.005 60)", "$type": "color" },
        "2": { "$value": "oklch(0.74 0.006 60)", "$type": "color" }
      }
    },

    "ink": {
      "$description": "Foreground type ramp. Step down for less weight; step up only for primary content.",
      "dark": {
        "1": { "$value": "oklch(0.97 0.004 60)", "$type": "color", "$description": "Primary content, headings, active labels" },
        "2": { "$value": "oklch(0.78 0.005 60)", "$type": "color", "$description": "Body, ghost button labels" },
        "3": { "$value": "oklch(0.55 0.005 60)", "$type": "color", "$description": "Secondary meta, hints, dashed dividers" },
        "4": { "$value": "oklch(0.40 0.006 60)", "$type": "color", "$description": "Tertiary — index numbers, ellipsis, dashes inside UUIDs" }
      },
      "light": {
        "1": { "$value": "oklch(0.18 0.006 60)", "$type": "color" },
        "2": { "$value": "oklch(0.34 0.006 60)", "$type": "color" },
        "3": { "$value": "oklch(0.50 0.006 60)", "$type": "color" },
        "4": { "$value": "oklch(0.65 0.006 60)", "$type": "color" }
      }
    },

    "accent": {
      "$description": "One accent at a time. All four palettes share L=0.78-0.86, C=0.18-0.20. Pick by hue.",
      "lime":    { "$value": "oklch(0.86 0.20 130)", "$type": "color", "on": "oklch(0.18 0.01 130)" },
      "amber":   { "$value": "oklch(0.82 0.18 65)",  "$type": "color", "on": "oklch(0.18 0.01 65)" },
      "cobalt":  { "$value": "oklch(0.74 0.18 250)", "$type": "color", "on": "oklch(0.16 0.01 250)" },
      "magenta": { "$value": "oklch(0.78 0.20 340)", "$type": "color", "on": "oklch(0.18 0.01 340)" }
    },

    "error": {
      "$description": "Invalid/error state. Warm red-orange hue 25. Follows the accent contract: --error for fills, borders, and text; --on-error for text on error fills. Light theme uses a darker value for contrast against near-white surfaces.",
      "dark":     { "$value": "oklch(0.72 0.17 25)", "$type": "color", "$description": "Default (dark theme) error indicator" },
      "light":    { "$value": "oklch(0.50 0.20 25)", "$type": "color", "$description": "Light theme override — darker for contrast" },
      "on-dark":  { "$value": "oklch(0.15 0.02 25)", "$type": "color", "$description": "Text on error fill (dark theme)" },
      "on-light": { "$value": "oklch(0.97 0.004 60)", "$type": "color", "$description": "Text on error fill (light theme)" }
    }
  },

  "font": {
    "family": {
      "sans": { "$value": "'Geist', ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "'Geist Mono', ui-monospace, 'JetBrains Mono', 'Menlo', monospace", "$type": "fontFamily" }
    },
    "feature-settings": {
      "sans": { "$value": "\"ss01\", \"ss02\", \"cv11\"", "$type": "string" },
      "mono": { "$value": "\"zero\", \"ss01\"", "$type": "string", "$description": "Slashed zero is non-negotiable for UUID legibility." }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "xxs":  { "$value": "10px", "$type": "dimension", "$description": "Hint text, dashed-divider meta" },
      "xs":   { "$value": "11px", "$type": "dimension", "$description": "kbd, status cells, eyebrow, row index" },
      "sm":   { "$value": "12px", "$type": "dimension", "$description": "Top bar, ghost button, panel title" },
      "base": { "$value": "13px", "$type": "dimension", "$description": "Body of dense controls, version titles" },
      "md":   { "$value": "14px", "$type": "dimension", "$description": "UUID rows" },
      "lg":   { "$value": "16px", "$type": "dimension", "$description": "Brand name, hero subhead" },
      "xl":   { "$value": "36px", "$type": "dimension", "$description": "Batch counter" },
      "hero": { "$value": "clamp(48px, 6.5vw, 88px)", "$type": "dimension" }
    },
    "tracking": {
      "tight":  { "$value": "-0.035em", "$type": "string", "$description": "Hero display" },
      "snug":   { "$value": "-0.01em",  "$type": "string", "$description": "Brand name" },
      "normal": { "$value": "0",        "$type": "string" },
      "wide":   { "$value": "0.04em",   "$type": "string", "$description": "Eyebrow, lowercase keys, panel flag" }
    },
    "line-height": {
      "display": { "$value": 0.96, "$type": "number" },
      "snug":    { "$value": 1.0,  "$type": "number" },
      "body":    { "$value": 1.55, "$type": "number" }
    }
  },

  "space": {
    "$description": "Mostly even values on a 4px base. Component padding is composed from these.",
    "0":  { "$value": "0",    "$type": "dimension" },
    "1":  { "$value": "2px",  "$type": "dimension" },
    "2":  { "$value": "4px",  "$type": "dimension" },
    "3":  { "$value": "6px",  "$type": "dimension" },
    "4":  { "$value": "8px",  "$type": "dimension" },
    "5":  { "$value": "10px", "$type": "dimension" },
    "6":  { "$value": "12px", "$type": "dimension" },
    "7":  { "$value": "14px", "$type": "dimension" },
    "8":  { "$value": "16px", "$type": "dimension" },
    "9":  { "$value": "18px", "$type": "dimension" },
    "10": { "$value": "22px", "$type": "dimension" },
    "11": { "$value": "24px", "$type": "dimension" },
    "12": { "$value": "28px", "$type": "dimension" },
    "13": { "$value": "36px", "$type": "dimension" },
    "14": { "$value": "40px", "$type": "dimension" },
    "15": { "$value": "80px", "$type": "dimension" }
  },

  "radius": {
    "xs":   { "$value": "4px",   "$type": "dimension", "$description": "kbd, version-tag, preset chip" },
    "sm":   { "$value": "5px",   "$type": "dimension", "$description": "row copy button" },
    "md":   { "$value": "6px",   "$type": "dimension", "$description": "Buttons, options, version rows" },
    "lg":   { "$value": "10px",  "$type": "dimension", "$description": "Workbench shell, modal" },
    "pill": { "$value": "999px", "$type": "dimension" }
  },

  "border": {
    "hairline": { "$value": "1px solid {color.seam.dark.1}", "$type": "border" },
    "elevated": { "$value": "1px solid {color.seam.dark.2}", "$type": "border" },
    "dashed":   { "$value": "1px dashed {color.seam.dark.1}", "$type": "border" }
  },

  "shadow": {
    "$description": "Glow uses the active accent. Modal-lift carries the only proper drop shadow in the system.",
    "accent-glow":   { "$value": "0 0 12px {color.accent.lime}", "$type": "shadow", "$description": "Brand-mark dot, status pulse" },
    "accent-glow-sm":{ "$value": "0 0 8px {color.accent.lime}",  "$type": "shadow" },
    "modal-lift":    { "$value": "0 20px 60px rgba(0,0,0,0.40)", "$type": "shadow" },
    "rail-active":   { "$value": "inset 2px 0 0 {color.accent.lime}", "$type": "shadow", "$description": "Active version row left bar" },
    "thumb-ring":    { "$value": "0 0 0 1px {color.accent.lime}", "$type": "shadow", "$description": "Range slider thumb halo" }
  },

  "motion": {
    "$description": "Short, purposeful transitions. UI feedback under 160ms, panel fades 220-280ms, reveal effects 380-700ms.",
    "duration": {
      "tap":     { "$value": "80ms",  "$type": "duration" },
      "swap":    { "$value": "120ms", "$type": "duration", "$description": "Hover/active state swap" },
      "settle":  { "$value": "140ms", "$type": "duration" },
      "scrim":   { "$value": "160ms", "$type": "duration" },
      "modal":   { "$value": "220ms", "$type": "duration" },
      "panel":   { "$value": "280ms", "$type": "duration" },
      "regen":   { "$value": "380ms", "$type": "duration", "$description": "Refresh icon spin window" },
      "spin":    { "$value": "700ms", "$type": "duration" },
      "pulse":   { "$value": "2000ms","$type": "duration" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.2, 0.7, 0.3, 1)", "$type": "cubicBezier", "$description": "Modal entry" },
      "linear":   { "$value": "linear", "$type": "cubicBezier" },
      "ease":     { "$value": "ease",   "$type": "cubicBezier" }
    }
  },

  "layout": {
    "container": {
      "max":    { "$value": "1440px", "$type": "dimension" },
      "gutter": { "$value": "28px",   "$type": "dimension" }
    },
    "rail-width":     { "$value": "320px", "$type": "dimension" },
    "row-grid":       { "$value": "50px 1fr 50px 90px", "$type": "string" },
    "version-grid":   { "$value": "32px 1fr 14px",     "$type": "string" },
    "modal-max":      { "$value": "560px", "$type": "dimension" },
    "topbar-pad":     { "$value": "14px 28px", "$type": "string" },
    "row-pad-comfy":  { "$value": "16px 18px", "$type": "string" },
    "row-pad-compact":{ "$value": "10px 16px", "$type": "string" },
    "breakpoint": {
      "fold": { "$value": "920px", "$type": "dimension", "$description": "Workbench collapses to single column" }
    },

    "z-index": {
      "$description": "Semantic layer scale. Never use arbitrary values outside this scale.",
      "sticky": { "$value": 10,  "$type": "number", "$description": "Sticky top bar and status bar" },
      "modal":  { "$value": 100, "$type": "number", "$description": "Modal scrim and dialog overlay" }
    }
  },

  "effect": {
    "blur-scrim":  { "$value": "blur(6px)",  "$type": "string" },
    "blur-topbar": { "$value": "blur(10px)", "$type": "string" },
    "scrim-bg":    { "$value": "color-mix(in oklch, {color.bg.dark.0}, transparent 30%)", "$type": "color" }
  }
}
