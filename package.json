{
  "name": "idlab",
  "private": true,
  "version": "1.11.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "docker:build": "docker build -t idlab:local .",
    "docker:run": "docker run --rm -p 8080:80 --name idlab-app --read-only --cap-drop ALL --tmpfs /var/cache/nginx:mode=1777 --tmpfs /var/run:mode=1777 --tmpfs /tmp:mode=1777 idlab:local"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "focus-trap-react": "^12.0.3",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "@eslint/config-array": "^0.23.2",
    "@eslint/eslintrc": "^3.3.1",
    "brace-expansion": "^5.0.6",
    "js-yaml": "^4.2.0",
    "undici": "^7.28.0"
  }
}
